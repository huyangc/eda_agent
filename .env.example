# =============================================================================
# EDA Agent — 环境变量配置示例
# 复制为 .env 并填入真实值后启动服务
# =============================================================================

# -----------------------------------------------------------------------------
# LLM 后端（agent 主模型）
# -----------------------------------------------------------------------------
LLM_BACKEND=openai          # openai | bedrock | ollama
LLM_MODEL=qwen3.5-27b     # 主生成模型（QA / TCL 回答）
TOOL_USE_MODEL=qwen3.5-27b # passthrough 工具调用决策用的快速模型（无需推理能力）

# OpenAI 兼容（DeepSeek / OpenAI 等）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Bedrock（仅 LLM_BACKEND=bedrock 时生效）
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Ollama（仅 LLM_BACKEND=ollama 时生效）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# RAG 服务（外部 HTTP 服务，默认 :9000）
# -----------------------------------------------------------------------------
RAG_SERVICE_URL=http://localhost:9000
RAG_TOP_K=6                 # 每次检索最多返回的文档数
RAG_SCORE_THRESHOLD=0.35    # 最低相似度分数阈值

# -----------------------------------------------------------------------------
# Agent 行为
# -----------------------------------------------------------------------------
INTENT_CONFIDENCE_THRESHOLD=0.7  # 低于此置信度仍走 EDA pipeline
MAX_COMMANDS_TO_RETRIEVE=5       # RAG 查询时最多提取的命令候选数

# -----------------------------------------------------------------------------
# 服务器
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 日志 & 追踪
# -----------------------------------------------------------------------------
LOG_DIR=logs                # session JSONL 存储根目录（按 YYYY-MM-DD/{HHMMSS}_{session}.jsonl 组织）
