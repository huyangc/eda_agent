# LLM Backend
LLM_BACKEND=openai          # openai | bedrock | ollama
LLM_MODEL=deepseek-reasoner
OPENAI_API_KEY=sk-fc0048d23a014e45a6f02a92f3fc61bf
OPENAI_BASE_URL=https://api.deepseek.com

# Bedrock (only needed if LLM_BACKEND=bedrock)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Ollama (only needed if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# External RAG Service
RAG_SERVICE_URL=http://localhost:9000
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.35

# Agent Behaviour
INTENT_CONFIDENCE_THRESHOLD=0.7
MAX_COMMANDS_TO_RETRIEVE=5
